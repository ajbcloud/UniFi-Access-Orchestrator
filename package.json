{
  "name": "unifi-access-orchestrator",
  "version": "10.7.0",
  "description": "Multi-door unlock automation for UniFi Access with built-in admin dashboard.",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "start:headless": "node src/index.js",
    "dev": "NODE_ENV=development electron .",
    "validate": "node src/validate.js",
    "test": "node --test",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:pi": "electron-builder --linux deb --armv7l",
    "build:all": "electron-builder --win --linux --mac"
  },
  "build": {
    "appId": "io.github.ajbcloud.unifi-access-orchestrator",
    "productName": "UniFi Access Orchestrator",
    "copyright": "Copyright (c) 2026 AJBCloud",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "assets/**/*",
      "config/config.example.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config/config.example.json",
        "to": "config/config.example.json"
      }
    ],
    "asarUnpack": [
      "node_modules/@serialport/**",
      "node_modules/@zwave-js/**",
      "node_modules/zwave-js/**",
      "**/*.node"
    ],
    "npmRebuild": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "UniFi Access Orchestrator"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "AJBCloud"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon-mac.png",
      "category": "public.app-category.utilities"
    }
  },
  "keywords": [
    "unifi",
    "unifi-access",
    "ubiquiti",
    "access-control",
    "door-unlock",
    "orchestrator",
    "electron",
    "raspberry-pi"
  ],
  "author": {
    "name": "AJBCloud",
    "url": "https://github.com/ajbcloud"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajbcloud/UniFi-Access-Orchestrator.git"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  },
  "optionalDependencies": {
    "zwave-js": "15.25.3",
    "nodemailer": "^6.9.16"
  }
}
